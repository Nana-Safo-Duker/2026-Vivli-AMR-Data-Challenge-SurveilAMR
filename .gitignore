# ---------------------------------------------------------------------------
# Local-only project data and documentation
# data/ holds Vivli-approved raw files and derived summaries; access is
# granted per-request under a Vivli Data Use Agreement and MUST NOT be
# redistributed, so the whole directory (raw and processed) is excluded.
# docs/ holds study protocols, checklists, and background notes supplied
# with the data request; kept locally rather than published in this repo.
# ---------------------------------------------------------------------------
data/
docs/

# Named raw datasets (in case they are ever dropped at the repo root)
atlas_vivli_*.csv
ATLAS_Antibiotics*.csv
BEDAQUILINE*DREAM*.xlsx
Omadacycline*Surveillance*.xlsx
GASAR*Study*III*.xlsx
spidaar_definitions.xls
spidaar_isolatedata.xls
spidaar_patientdata.xls

